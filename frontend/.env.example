#
# PlateauBreaker frontend environment variables (example)
#
# Copy to `frontend/.env` when you need to override the API base URL.
# Notes:
# - In dev, the Vite dev server proxies `/api` to the backend, so you usually don't need this.
# - Vite env vars are build-time; changing this requires restarting `npm run dev` or rebuilding.
#

# Optional. Full API base URL, e.g. "https://api.example.com/api".
# If unset, the app falls back to "/api" (works with the Vite dev proxy).
VITE_API_BASE_URL=

